# Backend voice + chat (loaded from repo root `.env` when you run `node server.js` from the repo root).
# The server resolves: `twin-ai-app/server/../../.env` — copy this block into the root `.env` file.

# Required for chat, RAG, and OpenAI TTS. Must be a secret key starting with `sk-`.
# Create at https://platform.openai.com/api-keys — never commit real values.
OPENAI_API_KEY=

# Text-to-speech model (OpenAI)
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# Optional: if OPENAI_API_KEY is unset or invalid, POST /tts can fall back to ElevenLabs (still server-side).
ELEVENLABS_API_KEY=

# Do NOT put OPENAI_API_KEY in `twin-ai-app/.env` for Expo — use only EXPO_PUBLIC_* URLs there so the app calls your backend.
