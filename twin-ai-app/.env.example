# Firebase Functions (HTTPS) — my-family-ai example: us-central1-my-family-ai.cloudfunctions.net
EXPO_PUBLIC_TRANSCRIBE_URL=https://REGION-PROJECT_ID.cloudfunctions.net/transcribe
# Host only (no /chat); used as base for transcribe/chat/tts defaults in services/api.ts
EXPO_PUBLIC_CHAT_URL=https://REGION-PROJECT_ID.cloudfunctions.net
EXPO_PUBLIC_TTS_URL=https://REGION-PROJECT_ID.cloudfunctions.net/tts
# Optional: local Express + RAG when EXPO_PUBLIC_CHAT_URL is Cloud Functions (defaults to LAN in api.ts)
EXPO_PUBLIC_RAG_BASE_URL=http://192.168.0.41:3000

# ElevenLabs (client-side TTS in the app; optional — falls back to EXPO_PUBLIC_TTS_URL)
EXPO_PUBLIC_ELEVENLABS_API_KEY=

# Firebase client (from Firebase Console → Project settings)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
