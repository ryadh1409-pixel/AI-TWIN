# Local voice + RAG (root: `node server.js` on port 3000). Use your Mac LAN IP — not localhost — so a real phone can connect.
# Example: if `ipconfig getifaddr en0` prints 192.168.1.23, set:
# EXPO_PUBLIC_RAG_BASE_URL=http://192.168.1.23:3000
EXPO_PUBLIC_RAG_BASE_URL=http://192.168.1.100:3000
# Optional overrides (defaults are RAG_BASE + /chat, /tts, /transcribe)
# EXPO_PUBLIC_CHAT_URL=http://192.168.1.100:3000
# EXPO_PUBLIC_TTS_URL=http://192.168.1.100:3000/tts
# EXPO_PUBLIC_TRANSCRIBE_URL=http://192.168.1.100:3000/transcribe

# Cloud Run (production-style) — uncomment and set RAG if not using LAN
# EXPO_PUBLIC_RAG_BASE_URL=https://chat-gehsfp2zqa-uc.a.run.app
# EXPO_PUBLIC_CHAT_URL=https://chat-gehsfp2zqa-uc.a.run.app
# EXPO_PUBLIC_TTS_URL=https://tts-gehsfp2zqa-uc.a.run.app
# EXPO_PUBLIC_TRANSCRIBE_URL=https://transcribe-gehsfp2zqa-uc.a.run.app

# Agent tools (Firebase Gen2 URLs after deploy; override if different)
EXPO_PUBLIC_GET_NEWS_URL=https://getnews-gehsfp2zqa-uc.a.run.app
EXPO_PUBLIC_SLEEP_STORY_URL=https://sleepstory-gehsfp2zqa-uc.a.run.app
# Firebase HTTPS function `decide` (POST / saves to Firestore `decisions`)
EXPO_PUBLIC_DECIDE_URL=https://us-central1-YOUR_PROJECT.cloudfunctions.net/decide
# Firebase HTTPS function `behaviorInsight` (POST /generate, POST /feedback)
EXPO_PUBLIC_BEHAVIOR_INSIGHT_URL=https://us-central1-YOUR_PROJECT.cloudfunctions.net/behaviorInsight
EXPO_PUBLIC_PREDICTION_URL=https://us-central1-YOUR_PROJECT.cloudfunctions.net/prediction

# ElevenLabs (optional client TTS; falls back to POST /tts)
EXPO_PUBLIC_ELEVENLABS_API_KEY=

# Firebase client (from Firebase Console → Project settings)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
