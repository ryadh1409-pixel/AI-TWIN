PORT=3000
HOST=0.0.0.0
OPENAI_API_KEY=

# Agent (POST /ask): GPT-4o + tools + Firestore memory
OPENAI_AGENT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Firebase Admin — required for long-term memory (Firestore)
# Option A: path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=
# Option B: entire JSON as a single line (e.g. CI)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Web search (use ONE option)
# Google Custom Search JSON API — create at https://programmablesearchengine.google.com/
GOOGLE_CSE_API_KEY=
# Or reuse a generic Google API key if you use it for CSE:
# GOOGLE_API_KEY=
GOOGLE_CSE_ID=
# SerpAPI — if set, it takes priority over Google CSE
SERPAPI_KEY=

ELEVENLABS_API_KEY=
# Places API (Nearby Search) — same Google Cloud key if Places enabled for the project
GOOGLE_PLACES_API_KEY=

# X7 AI Twin (Firebase Functions): use Secret Manager, not this file:
#   firebase functions:secrets:set OPENAI_API_KEY
# Optional override:
# OPENAI_CHAT_MODEL=gpt-4o-mini
