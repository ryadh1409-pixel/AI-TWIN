    "@langchain/openai": "^1.4.4",
    "@langchain/textsplitters": "^1.0.1",
    "buffer": "^6.0.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "expo": "~54.0.33",
    "express": "^5.2.1",
    "faiss-node": "^0.5.1",
    "firebase-admin": "^13.8.0",
    "langchain": "^1.3.3",
    "mathjs": "^15.2.0",
    "multer": "^1.4.5-lts.2",
    "openai": "^6.34.0",
    "pdf-parse": "^1.1.4",
    "react": "^19.1.0",
    "react-dom": "19.1.0",
    "react-native": "^0.81.5",
    "react-native-web": "^0.21.0"
  },
  "nodemonConfig": {
