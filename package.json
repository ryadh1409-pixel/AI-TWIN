{
  "name": "my-family-ai",
  "private": true,
  "scripts": {
    "server": "node server.js",
    "server:twin-only": "npm run server --prefix twin-ai-app",
    "app": "npm start --prefix twin-ai-app",
    "dev": "concurrently \"node server.js\" \"npm start --prefix twin-ai-app\"",
    "deploy:functions": "firebase deploy --only functions",
    "emulate:functions": "firebase emulators:start --only functions"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "firebase-tools": "^14.0.1",
    "nodemon": "^3.1.10",
    "typescript": "~5.9.2"
  },
